# BoxBox — Environment Variables
# Copia questo file in .env e compila i valori

# MotoGP Fantasy League ID (default: 5287)
LEAGUE_ID=5287

# Cookie di sessione (alternativa: generare via renew-dat.mjs)
# Ottenere da: F12 su fantasy.motogp.com → Network → Cookie header
COOKIE_FULL=

# Per auto-renew cookie via Playwright (opzionale)
EMAIL=
PASSWORD=

# URL Chrome DevTools Protocol (opzionale, default: http://localhost:9222)
# CDP_URL=http://localhost:9222
